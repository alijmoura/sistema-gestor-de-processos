rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===================== FUNÇÕES AUXILIARES =====================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return request.auth != null && request.auth.token.admin == true;
    }

    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    function userTenantDocId(empresaId) {
      return request.auth.uid + "_" + empresaId;
    }

    function hasTenantAccess(empresaId) {
      return isAdmin()
        || (
          isAuthenticated()
          && empresaId is string
          && exists(/databases/$(database)/documents/user_tenants/$(userTenantDocId(empresaId)))
          && get(/databases/$(database)/documents/user_tenants/$(userTenantDocId(empresaId))).data.status == "ativo"
        );
    }

    function isTenantAdmin(empresaId) {
      return isAdmin()
        || (
          hasTenantAccess(empresaId)
          && get(/databases/$(database)/documents/user_tenants/$(userTenantDocId(empresaId))).data.role in ["empresa_admin", "admin", "super_admin"]
        );
    }

    function hasTenantReadAccess() {
      return resource.data.empresaId is string
        && hasTenantAccess(resource.data.empresaId);
    }

    function hasTenantCreateAccess() {
      return request.resource.data.empresaId is string
        && request.resource.data.tenantId == request.resource.data.empresaId
        && hasTenantAccess(request.resource.data.empresaId);
    }

    function hasTenantUpdateAccess() {
      return resource.data.empresaId is string
        && request.resource.data.empresaId == resource.data.empresaId
        && request.resource.data.tenantId == resource.data.empresaId
        && hasTenantAccess(resource.data.empresaId);
    }

    function isTenantDocAdmin() {
      return resource.data.empresaId is string
        && isTenantAdmin(resource.data.empresaId);
    }

    function parentTenantAccess(collectionName, docId) {
      return exists(/databases/$(database)/documents/$(collectionName)/$(docId))
        && get(/databases/$(database)/documents/$(collectionName)/$(docId)).data.empresaId is string
        && hasTenantAccess(get(/databases/$(database)/documents/$(collectionName)/$(docId)).data.empresaId);
    }

    function parentTenantAdmin(collectionName, docId) {
      return exists(/databases/$(database)/documents/$(collectionName)/$(docId))
        && get(/databases/$(database)/documents/$(collectionName)/$(docId)).data.empresaId is string
        && isTenantAdmin(get(/databases/$(database)/documents/$(collectionName)/$(docId)).data.empresaId);
    }

    match /empresas/{empresaId} {
      allow read: if hasTenantAccess(empresaId);
      allow create, update, delete: if isAdmin();
    }

    match /user_tenants/{membershipId} {
      allow read: if isAdmin()
        || (
          isAuthenticated()
          && resource.data.uid == request.auth.uid
          && hasTenantAccess(resource.data.empresaId)
        )
        || (
          isAuthenticated()
          && isTenantAdmin(resource.data.empresaId)
        );

      allow create, update, delete: if isAdmin()
        || (
          isAuthenticated()
          && request.resource.data.empresaId is string
          && isTenantAdmin(request.resource.data.empresaId)
        );
    }

    match /tenant_settings/{settingId} {
      allow read: if hasTenantAccess(resource.data.empresaId);
      allow create: if hasTenantAccess(request.resource.data.empresaId);
      allow update, delete: if isTenantAdmin(resource.data.empresaId);
    }
    
    // Coleção de contratos
    match /contracts/{contractId} {
      allow read: if hasTenantReadAccess();
      allow create: if hasTenantCreateAccess();
      allow update: if hasTenantUpdateAccess();
      allow delete: if isTenantDocAdmin();
      
      // Subcoleção de histórico do contrato
      match /historico/{historicoId} {
        allow read: if parentTenantAccess("contracts", contractId);
        allow create: if parentTenantAccess("contracts", contractId);
        allow update: if parentTenantAccess("contracts", contractId);
        allow delete: if parentTenantAdmin("contracts", contractId);
      }
      
      // Subcoleção de anexos do contrato
      match /anexos/{anexoId} {
        allow read: if parentTenantAccess("contracts", contractId);
        allow create: if parentTenantAccess("contracts", contractId);
        allow update: if parentTenantAccess("contracts", contractId);
        allow delete: if parentTenantAccess("contracts", contractId);
      }
      
      // Subcoleção de erros (QA) do contrato
      match /erros/{erroId} {
        allow read: if parentTenantAccess("contracts", contractId);
        allow create: if parentTenantAccess("contracts", contractId);
        allow update: if parentTenantAdmin("contracts", contractId);
        allow delete: if parentTenantAdmin("contracts", contractId)
          || resource.data.criadoPor == request.auth.uid
          || resource.data.criadoPor == request.auth.token.email
          || resource.data.criadoPorEmail == request.auth.token.email
          || resource.data.createdBy == request.auth.uid
          || resource.data.createdBy == request.auth.token.email
          || resource.data.createdByUid == request.auth.uid
          || resource.data.createdByEmail == request.auth.token.email;
      }
    }
    
    // Coleção de usuários (regras existentes - manter como está)
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if isOwner(userId) || isAdmin();

      // Histórico de notificações WhatsApp por usuário
      match /whatsappNotifications/{notificationId} {
        allow read: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId) || isAdmin();
        allow update: if isOwner(userId) || isAdmin();
        allow delete: if isOwner(userId) || isAdmin();
      }
    }

    // Coleção de segurança de senha
    match /user_security/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isAdmin();
    }
    
    // Coleção de status (regras existentes - manter como está)
    match /statusConfig/{docId} {
      allow read: if hasTenantReadAccess();
      allow create: if hasTenantCreateAccess();
      allow update: if hasTenantUpdateAccess();
      allow delete: if isTenantDocAdmin();
    }

    // Coleção de status dinâmicos (nova regra)
    match /status/{docId} {
      allow read: if hasTenantReadAccess();
      allow create: if hasTenantCreateAccess();
      allow update: if hasTenantUpdateAccess();
      allow delete: if isTenantDocAdmin();
    }

    // Coleção de regras de status (validação de campos obrigatórios)
    match /statusRules/{docId} {
      allow read: if hasTenantReadAccess();
      allow create: if hasTenantCreateAccess();
      allow update: if hasTenantUpdateAccess();
      allow delete: if isTenantDocAdmin();
    }

    // Coleção de configurações gerais (Dashboard, etc.)
    match /settings/{settingId} {
      allow read: if hasTenantReadAccess();
      allow create: if hasTenantCreateAccess();
      allow update: if hasTenantUpdateAccess();
      allow delete: if isTenantDocAdmin();
    }

    // Coleção de contratos arquivados
    match /archivedContracts/{contractId} {
      allow read: if hasTenantReadAccess();
      allow create: if hasTenantCreateAccess();
      allow update: if hasTenantUpdateAccess();
      allow delete: if isTenantDocAdmin();

      match /historico/{historicoId} {
        allow read: if parentTenantAccess("archivedContracts", contractId);
        allow write: if parentTenantAdmin("archivedContracts", contractId);
      }

      match /anexos/{anexoId} {
        allow read: if parentTenantAccess("archivedContracts", contractId);
        allow write: if parentTenantAccess("archivedContracts", contractId);
      }
    }

    // ===================== REGRAS PERMISSÕES DE USUÁRIOS (NOVO SISTEMA) =====================
    
    // Coleção de permissões de usuários
    match /user_permissions/{userId} {
      // Leitura: Próprio usuário pode ler suas permissões, ou admin pode ler todas
      allow read: if isOwner(userId) || isAdmin();
      
      // Escrita: Apenas admin pode modificar permissões
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }
    
    // ===================== REGRAS PENDÊNCIAS =====================

    // Coleção de pendências
    match /pendencias/{pendenciaId} {
      allow read: if hasTenantReadAccess();
      allow create: if hasTenantCreateAccess();
      allow update: if hasTenantUpdateAccess();
      allow delete: if isTenantDocAdmin() || (isAuthenticated() && resource.data.createdBy == request.auth.uid);
    }

    // ===================== REGRAS APROVAÇÕES =====================

    // Coleção de aprovações de crédito
    match /aprovacoes/{aprovacaoId} {
      allow read: if hasTenantReadAccess();
      allow create: if hasTenantCreateAccess();
      allow update: if hasTenantUpdateAccess();
      allow delete: if isTenantDocAdmin()
        || resource.data.criadoPor == request.auth.uid
        || resource.data.criadoPor == request.auth.token.email
        || resource.data.createdBy == request.auth.uid
        || resource.data.createdBy == request.auth.token.email;

      match /erros/{erroId} {
        allow read: if parentTenantAccess("aprovacoes", aprovacaoId);
        allow create: if parentTenantAccess("aprovacoes", aprovacaoId);
        allow update: if parentTenantAdmin("aprovacoes", aprovacaoId);
        allow delete: if parentTenantAdmin("aprovacoes", aprovacaoId)
          || resource.data.criadoPor == request.auth.uid
          || resource.data.criadoPor == request.auth.token.email
          || resource.data.criadoPorEmail == request.auth.token.email
          || resource.data.createdBy == request.auth.uid
          || resource.data.createdBy == request.auth.token.email
          || resource.data.createdByUid == request.auth.uid
          || resource.data.createdByEmail == request.auth.token.email;
      }
    }
    
    // ===================== REGRAS WHATSAPP (NOVAS) =====================
    
    // Configuração WhatsApp
    match /whatsappConfig/settings {
      allow read: if hasTenantReadAccess();
      allow create: if hasTenantCreateAccess();
      allow update: if hasTenantUpdateAccess();
      allow delete: if isTenantDocAdmin();
    }
    
    // Conversas WhatsApp
    match /chats/{chatId} {
      allow read: if hasTenantReadAccess();
      allow create: if hasTenantCreateAccess();
      allow update: if hasTenantUpdateAccess();
      allow delete: if isTenantDocAdmin();

      match /messages/{messageId} {
        allow read: if parentTenantAccess("chats", chatId);
        allow create: if parentTenantAccess("chats", chatId);
        allow update: if parentTenantAccess("chats", chatId);
        allow delete: if parentTenantAdmin("chats", chatId);
      }
    }
    
    // Mensagens rápidas (Quick Messages)
    match /quickMessages/{quickMessageId} {
      allow read: if hasTenantReadAccess();
      allow create: if hasTenantCreateAccess();
      allow update: if hasTenantUpdateAccess();
      allow delete: if isTenantDocAdmin();
    }
    
    // Filas por departamento (apenas leitura para agentes)
    match /whatsappQueues/{whatsappQueueId} {
      allow read: if hasTenantReadAccess();
      allow create: if hasTenantCreateAccess();
      allow update: if hasTenantUpdateAccess();
      allow delete: if isTenantDocAdmin();
    }
    
    // Tags do WhatsApp
    match /whatsappTags/{whatsappTagId} {
      allow read: if hasTenantReadAccess();
      allow create: if hasTenantCreateAccess();
      allow update: if hasTenantUpdateAccess();
      allow delete: if isTenantDocAdmin();
    }
    
    // Números de telefone WhatsApp
    match /whatsappPhones/{whatsappPhoneId} {
      allow read: if hasTenantReadAccess();
      allow create: if hasTenantCreateAccess();
      allow update: if hasTenantUpdateAccess();
      allow delete: if isTenantDocAdmin();
    }
    
    // Números de telefone WhatsApp (coleção correta)
    match /whatsappPhoneNumbers/{whatsappPhoneNumberId} {
      allow read: if hasTenantReadAccess();
      allow create: if hasTenantCreateAccess();
      allow update: if hasTenantUpdateAccess();
      allow delete: if isTenantDocAdmin();
    }
    
    // ===================== REGRAS COLEÇÕES AUXILIARES =====================
    
    // Vendedores/Construtoras - Leitura para todos, escrita apenas admin
    match /vendors/{vendorId} {
      allow read: if hasTenantReadAccess();
      allow create: if hasTenantCreateAccess();
      allow update: if hasTenantUpdateAccess();
      allow delete: if isTenantDocAdmin();
    }
    
    // Agências - Leitura para todos, escrita apenas admin
    match /agencias/{agenciaId} {
      allow read: if hasTenantReadAccess();
      allow create: if hasTenantCreateAccess();
      allow update: if hasTenantUpdateAccess();
      allow delete: if isTenantDocAdmin();
    }
    
    // Cartórios - Leitura para todos, escrita apenas admin
    match /cartorios/{cartorioId} {
      allow read: if hasTenantReadAccess();
      allow create: if hasTenantCreateAccess();
      allow update: if hasTenantUpdateAccess();
      allow delete: if isTenantDocAdmin();
    }
    
    // Workflows - Leitura para todos, escrita apenas admin
    match /workflows/{workflowId} {
      allow read: if hasTenantReadAccess();
      allow create: if hasTenantCreateAccess();
      allow update: if hasTenantUpdateAccess();
      allow delete: if isTenantDocAdmin();
    }
    
    // Configurações do Dashboard - Leitura para todos, escrita apenas admin
    match /dashboardConfig/{docId} {
      allow read: if hasTenantReadAccess();
      allow create: if hasTenantCreateAccess();
      allow update: if hasTenantUpdateAccess();
      allow delete: if isTenantDocAdmin();
    }

    // Configurações de SLA por status - Leitura para todos, escrita apenas admin
    match /slaConfig/{docId} {
      allow read: if hasTenantReadAccess();
      allow create: if hasTenantCreateAccess();
      allow update: if hasTenantUpdateAccess();
      allow delete: if isTenantDocAdmin();
    }

    // Configurações de SLA por datas - Leitura para todos, escrita apenas admin
    match /slaDateConfig/{docId} {
      allow read: if hasTenantReadAccess();
      allow create: if hasTenantCreateAccess();
      allow update: if hasTenantUpdateAccess();
      allow delete: if isTenantDocAdmin();
    }
    
    // Anexos de contratos - Baseado em permissões de contrato
    match /attachments/{attachmentId} {
      allow read: if hasTenantReadAccess();
      allow create: if hasTenantCreateAccess();
      allow update: if hasTenantUpdateAccess();
      allow delete: if isTenantDocAdmin();
    }

    // ===================== AGENDA / EVENTOS =====================

    // Coleção de eventos do calendário - Cada usuário gerencia seus próprios eventos
    match /events/{eventId} {
      allow read: if hasTenantReadAccess();
      allow create: if hasTenantCreateAccess();
      allow update: if hasTenantUpdateAccess();
      allow delete: if isTenantDocAdmin();
    }

    // Tipos de agendamento - Cada usuário gerencia seus próprios tipos customizados
    match /scheduleTypes/{scheduleTypeId} {
      allow read: if hasTenantReadAccess();
      allow create: if hasTenantCreateAccess();
      allow update: if hasTenantUpdateAccess();
      allow delete: if isTenantDocAdmin();
    }
    
    // ===================== CHAT INTERNO ENTRE ANALISTAS =====================

    // Conversas do chat interno
    match /analystChats/{chatId} {
      // Leitura: apenas participantes da conversa
      allow read: if isAuthenticated()
                  && request.auth.uid in resource.data.participants;

      // Criacao: usuario autenticado deve fazer parte dos participantes
      allow create: if isAuthenticated()
                    && request.resource.data.participants is list
                    && request.resource.data.participants.size() >= 2
                    && request.auth.uid in request.resource.data.participants;

      // Atualizacao: apenas participantes da conversa
      allow update: if isAuthenticated()
                    && request.auth.uid in resource.data.participants;

      // Delecao: apenas admin
      allow delete: if isAdmin();

      // Subcolecao de mensagens
      match /messages/{messageId} {
        // Apenas participantes do chat pai
        allow read: if isAuthenticated()
                    && request.auth.uid in get(/databases/$(database)/documents/analystChats/$(chatId)).data.participants;

        // Criacao: participante do chat + senderUid deve ser o proprio usuario
        allow create: if isAuthenticated()
                      && request.auth.uid in get(/databases/$(database)/documents/analystChats/$(chatId)).data.participants
                      && request.resource.data.senderUid == request.auth.uid;

        // Update: apenas participantes (ex.: readBy)
        allow update: if isAuthenticated()
                      && request.auth.uid in get(/databases/$(database)/documents/analystChats/$(chatId)).data.participants;

        allow delete: if isAdmin();
      }
    }

    // ===================== CONVERSAS DE IA =====================

    // Coleção de conversas do Assistente IA
    match /aiConversations/{userId} {
      allow read, write: if isAuthenticated() && isOwner(userId);

      // Subcoleção de mensagens
      match /messages/{messageId} {
        allow read, write: if isAuthenticated() && isOwner(userId);
      }
    }

    // ===================== MÉTRICAS DE LEITURAS =====================

    // Coleção de métricas de leituras do Firestore
    match /_readMetrics/{metricId} {
      // Leitura: Admin pode ver todas; usuário autenticado pode ver apenas suas próprias métricas
      allow read: if isAdmin() ||
                     (isAuthenticated() && metricId.matches('.*_' + request.auth.uid + '$'));

      // Escrita: Usuários autenticados podem registrar suas próprias métricas
      // O docId segue o formato: YYYY-MM-DD_userId
      allow create: if isAuthenticated() &&
                       metricId.matches('.*_' + request.auth.uid + '$');
      allow update: if isAuthenticated() &&
                       metricId.matches('.*_' + request.auth.uid + '$');

      // Deleção: Apenas admin ou Cloud Functions (via scheduler)
      allow delete: if isAdmin();
    }

    // ===================== SINCRONIZAÇÃO EM TEMPO REAL =====================
    
    // Coleção de notificações em tempo real (lightweight)
    match /realtimeNotifications/{realtimeNotificationId} {
      allow read: if hasTenantReadAccess();
      allow create: if hasTenantCreateAccess();
      allow update: if hasTenantUpdateAccess();
      allow delete: if isTenantDocAdmin();
    }

    // Notificações de delta para aprovações (somente backend grava)
    match /realtimeAprovacaoNotifications/{realtimeAprovacaoNotificationId} {
      allow read: if hasTenantReadAccess();
      allow create: if hasTenantCreateAccess();
      allow update: if hasTenantUpdateAccess();
      allow delete: if isTenantDocAdmin();
    }

    // Agregados diários de aprovações (somente leitura no cliente)
    match /aprovacoesAggDaily/{docId} {
      allow read: if hasTenantReadAccess();
      allow create: if hasTenantCreateAccess();
      allow update: if hasTenantUpdateAccess();
      allow delete: if isTenantDocAdmin();
    }

    // Agregado global de aprovações (somente leitura no cliente)
    match /aprovacoesAggSummary/{docId} {
      allow read: if hasTenantReadAccess();
      allow create: if hasTenantCreateAccess();
      allow update: if hasTenantUpdateAccess();
      allow delete: if isTenantDocAdmin();
    }

    // Links de conversão aprovação -> processo materializados no backend
    match /aprovacaoConversaoLinks/{aprovacaoConversaoLinkId} {
      allow read: if hasTenantReadAccess();
      allow create: if hasTenantCreateAccess();
      allow update: if hasTenantUpdateAccess();
      allow delete: if isTenantDocAdmin();
    }

    // ===================== LOGS DE ATIVIDADE =====================
    
    // Logs de atividade do sistema
    match /activity_logs/{activityId} {
      allow read: if isTenantDocAdmin() || (hasTenantReadAccess() && resource.data.userUid == request.auth.uid);
      allow create: if hasTenantCreateAccess() && request.resource.data.userUid == request.auth.uid;
      allow update, delete: if isTenantDocAdmin();
    }

    // ===================== REGRAS PADRÃO =====================

    // Qualquer outra coleção - requer admin
    match /{document=**} {
      allow read, write: if isAdmin();
    }
  }
}
