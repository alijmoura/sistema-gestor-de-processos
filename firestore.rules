rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===================== FUNÇÕES AUXILIARES =====================
    
    // Verifica se o usuário está autenticado
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Verifica se o usuário é admin
    function isAdmin() {
      return request.auth != null && request.auth.token.admin == true;
    }
    
    // Verifica se o usuário é o próprio
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }
    
    // Verifica se o usuário é um agente WhatsApp registrado
    function isWhatsAppAgent() {
      return isAuthenticated() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.whatsapp.isAgent == true;
    }
    
    // Verifica se o agente está atribuído ao chat
    function isAssignedAgent(chatId) {
      return isAuthenticated() && 
             get(/databases/$(database)/documents/chats/$(chatId)).data.agentId == request.auth.uid;
    }
    
    // ===================== REGRAS EXISTENTES (mantidas) =====================
    
    // Coleção de contratos
    match /contracts/{contractId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isAdmin(); // ✅ APENAS ADMIN PODE EXCLUIR
      
      // Subcoleção de histórico do contrato
      match /historico/{historicoId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated();
        allow update: if isAuthenticated();
        allow delete: if isAdmin();
      }
      
      // Subcoleção de anexos do contrato
      match /anexos/{anexoId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated();
        allow update: if isAuthenticated();
        allow delete: if isAuthenticated() || isAdmin();
      }
      
      // Subcoleção de erros (QA) do contrato
      match /erros/{erroId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated();
        allow update: if isAdmin(); // Apenas admin pode avaliar (aprovar/rejeitar)
        allow delete: if isAdmin()
          || resource.data.criadoPor == request.auth.uid
          || resource.data.criadoPor == request.auth.token.email
          || resource.data.criadoPorEmail == request.auth.token.email
          || resource.data.createdBy == request.auth.uid
          || resource.data.createdBy == request.auth.token.email
          || resource.data.createdByUid == request.auth.uid
          || resource.data.createdByEmail == request.auth.token.email;
      }
    }
    
    // Coleção de usuários (regras existentes - manter como está)
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if isOwner(userId) || isAdmin();

      // Histórico de notificações WhatsApp por usuário
      match /whatsappNotifications/{notificationId} {
        allow read: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId) || isAdmin();
        allow update: if isOwner(userId) || isAdmin();
        allow delete: if isOwner(userId) || isAdmin();
      }
    }

    // Coleção de segurança de senha
    match /user_security/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isAdmin();
    }
    
    // Coleção de status (regras existentes - manter como está)
    match /statusConfig/{statusId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Coleção de status dinâmicos (nova regra)
    match /status/{statusId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Coleção de regras de status (validação de campos obrigatórios)
    match /statusRules/{ruleId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Coleção de configurações gerais (Dashboard, etc.)
    match /settings/{settingId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Coleção de contratos arquivados
    match /archivedContracts/{contractId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated(); // Se necessário
      allow update: if isAuthenticated(); // Se necessário
      allow delete: if isAdmin();
      
      // Subcoleção de histórico
      match /historico/{historicoId} {
        allow read: if isAuthenticated();
        allow write: if isAdmin(); // Geralmente histórico é imutável ou gerado pelo sistema
      }
      
      // Subcoleção de anexos
      match /anexos/{anexoId} {
        allow read: if isAuthenticated();
        // Permissões similares a contracts
        allow write: if isAuthenticated(); 
      }
    }

    // ===================== REGRAS PERMISSÕES DE USUÁRIOS (NOVO SISTEMA) =====================
    
    // Coleção de permissões de usuários
    match /user_permissions/{userId} {
      // Leitura: Próprio usuário pode ler suas permissões, ou admin pode ler todas
      allow read: if isOwner(userId) || isAdmin();
      
      // Escrita: Apenas admin pode modificar permissões
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }
    
    // ===================== REGRAS PENDÊNCIAS =====================

    // Coleção de pendências
    match /pendencias/{pendenciaId} {
      // Qualquer usuário autenticado pode ler pendências
      allow read: if isAuthenticated();

      // Criar: Qualquer usuário autenticado
      allow create: if isAuthenticated();

      // Atualizar: Qualquer usuário autenticado (editar, concluir, reabrir)
      allow update: if isAuthenticated();

      // Excluir: Qualquer usuário autenticado
      allow delete: if isAuthenticated();
    }

    // ===================== REGRAS APROVAÇÕES =====================

    // Coleção de aprovações de crédito
    match /aprovacoes/{aprovacaoId} {
      // Leitura: Qualquer usuário autenticado pode ler aprovações
      allow read: if isAuthenticated();

      // Criar: Qualquer usuário autenticado pode criar aprovações
      allow create: if isAuthenticated();

      // Atualizar: Qualquer usuário autenticado pode atualizar
      allow update: if isAuthenticated();

      // Excluir: Admin ou criador da analise
      allow delete: if isAdmin()
        || resource.data.criadoPor == request.auth.uid
        || resource.data.criadoPor == request.auth.token.email
        || resource.data.createdBy == request.auth.uid
        || resource.data.createdBy == request.auth.token.email;
      
      // Subcoleção de erros (QA) da aprovacao
      match /erros/{erroId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated();
        allow update: if isAdmin(); // Apenas admin pode avaliar (aprovar/rejeitar)
        allow delete: if isAdmin()
          || resource.data.criadoPor == request.auth.uid
          || resource.data.criadoPor == request.auth.token.email
          || resource.data.criadoPorEmail == request.auth.token.email
          || resource.data.createdBy == request.auth.uid
          || resource.data.createdBy == request.auth.token.email
          || resource.data.createdByUid == request.auth.uid
          || resource.data.createdByEmail == request.auth.token.email;
      }
    }
    
    // ===================== REGRAS WHATSAPP (NOVAS) =====================
    
    // Configuração WhatsApp
    match /whatsappConfig/settings {
      allow read: if isAuthenticated();  // Todos podem ler configuração
      allow write: if isAdmin();  // Apenas admin pode modificar
    }
    
    // Conversas WhatsApp
    match /chats/{chatId} {
      // ✅ MODIFICADO: Leitura para todos autenticados (necessário para vincular contratos)
      allow read: if isAuthenticated();
      
      // Criação: Usuários autenticados podem criar conversas
      allow create: if isAuthenticated();
      
      // Atualização: Usuários autenticados podem atribuir/atualizar chats
      allow update: if isAuthenticated();
      
      // Deleção: Apenas admin
      allow delete: if isAdmin();
      
      // Mensagens da conversa (subcoleção)
      match /messages/{messageId} {
        // ✅ MODIFICADO: Leitura para todos autenticados
        allow read: if isAuthenticated();
        
        // Criação: Usuários autenticados podem criar mensagens
        allow create: if isAuthenticated();
        
        // Atualização: Usuários autenticados podem atualizar (ex: marcar como lida)
        allow update: if isAuthenticated();
        
        // Deleção: Apenas admin
        allow delete: if isAdmin();
      }
    }
    
    // Mensagens rápidas (Quick Messages)
    match /quickMessages/{messageId} {
      // Leitura: Qualquer agente WhatsApp
      allow read: if isWhatsAppAgent() || isAdmin();
      
      // Criação/Atualização: Qualquer agente pode criar suas mensagens
      allow create: if isWhatsAppAgent() || isAdmin();
      allow update: if isWhatsAppAgent() || isAdmin();
      
      // Deleção: Apenas quem criou ou admin
      allow delete: if isAdmin() || 
                      (isAuthenticated() && 
                       resource.data.createdBy == request.auth.uid);
    }
    
    // Filas por departamento (apenas leitura para agentes)
    match /whatsappQueues/{queueId} {
      allow read: if isWhatsAppAgent() || isAdmin();
      allow write: if isAdmin(); // Apenas sistema gerencia filas
    }
    
    // Tags do WhatsApp
    match /whatsappTags/{tagId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isAdmin() || 
                      (isAuthenticated() && 
                       resource.data.createdBy == request.auth.uid);
    }
    
    // Números de telefone WhatsApp
    match /whatsappPhones/{phoneId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    
    // Números de telefone WhatsApp (coleção correta)
    match /whatsappPhoneNumbers/{phoneId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    
    // ===================== REGRAS COLEÇÕES AUXILIARES =====================
    
    // Vendedores/Construtoras - Leitura para todos, escrita apenas admin
    match /vendors/{vendorId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    
    // Agências - Leitura para todos, escrita apenas admin
    match /agencias/{agenciaId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    
    // Cartórios - Leitura para todos, escrita apenas admin
    match /cartorios/{cartorioId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    
    // Workflows - Leitura para todos, escrita apenas admin
    match /workflows/{workflowId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    
    // Configurações do Dashboard - Leitura para todos, escrita apenas admin
    match /dashboardConfig/{configId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Configurações de SLA por status - Leitura para todos, escrita apenas admin
    match /slaConfig/{configId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Configurações de SLA por datas - Leitura para todos, escrita apenas admin
    match /slaDateConfig/{configId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    
    // Anexos de contratos - Baseado em permissões de contrato
    match /attachments/{attachmentId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if (isAuthenticated() && resource.data.uploadedBy == request.auth.uid) || isAdmin();
      allow delete: if (isAuthenticated() && resource.data.uploadedBy == request.auth.uid) || isAdmin();
    }

    // ===================== AGENDA / EVENTOS =====================

    // Coleção de eventos do calendário - Cada usuário gerencia seus próprios eventos
    match /events/{eventId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isAuthenticated()
                    && (resource.data.createdBy == request.auth.uid || isAdmin());
    }

    // Tipos de agendamento - Cada usuário gerencia seus próprios tipos customizados
    match /scheduleTypes/{typeId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated()
                    && (resource.data.createdBy == request.auth.uid || isAdmin());
      allow delete: if isAuthenticated()
                    && (resource.data.createdBy == request.auth.uid || isAdmin());
    }
    
    // ===================== CHAT INTERNO ENTRE ANALISTAS =====================

    // Conversas do chat interno
    match /analystChats/{chatId} {
      // Leitura: apenas participantes da conversa
      allow read: if isAuthenticated()
                  && request.auth.uid in resource.data.participants;

      // Criacao: usuario autenticado deve fazer parte dos participantes
      allow create: if isAuthenticated()
                    && request.resource.data.participants is list
                    && request.resource.data.participants.size() >= 2
                    && request.auth.uid in request.resource.data.participants;

      // Atualizacao: apenas participantes da conversa
      allow update: if isAuthenticated()
                    && request.auth.uid in resource.data.participants;

      // Delecao: apenas admin
      allow delete: if isAdmin();

      // Subcolecao de mensagens
      match /messages/{messageId} {
        // Apenas participantes do chat pai
        allow read: if isAuthenticated()
                    && request.auth.uid in get(/databases/$(database)/documents/analystChats/$(chatId)).data.participants;

        // Criacao: participante do chat + senderUid deve ser o proprio usuario
        allow create: if isAuthenticated()
                      && request.auth.uid in get(/databases/$(database)/documents/analystChats/$(chatId)).data.participants
                      && request.resource.data.senderUid == request.auth.uid;

        // Update: apenas participantes (ex.: readBy)
        allow update: if isAuthenticated()
                      && request.auth.uid in get(/databases/$(database)/documents/analystChats/$(chatId)).data.participants;

        allow delete: if isAdmin();
      }
    }

    // ===================== CONVERSAS DE IA =====================

    // Coleção de conversas do Assistente IA
    match /aiConversations/{userId} {
      allow read, write: if isAuthenticated() && isOwner(userId);

      // Subcoleção de mensagens
      match /messages/{messageId} {
        allow read, write: if isAuthenticated() && isOwner(userId);
      }
    }

    // ===================== MÉTRICAS DE LEITURAS =====================

    // Coleção de métricas de leituras do Firestore
    match /_readMetrics/{metricId} {
      // Leitura: Admin pode ver todas; usuário autenticado pode ver apenas suas próprias métricas
      allow read: if isAdmin() ||
                     (isAuthenticated() && metricId.matches('.*_' + request.auth.uid + '$'));

      // Escrita: Usuários autenticados podem registrar suas próprias métricas
      // O docId segue o formato: YYYY-MM-DD_userId
      allow create: if isAuthenticated() &&
                       metricId.matches('.*_' + request.auth.uid + '$');
      allow update: if isAuthenticated() &&
                       metricId.matches('.*_' + request.auth.uid + '$');

      // Deleção: Apenas admin ou Cloud Functions (via scheduler)
      allow delete: if isAdmin();
    }

    // ===================== SINCRONIZAÇÃO EM TEMPO REAL =====================
    
    // Coleção de notificações em tempo real (lightweight)
    match /realtimeNotifications/{notificationId} {
      // Qualquer usuário autenticado pode criar notificações
      allow create: if isAuthenticated() 
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.timestamp is timestamp;
      
      // Qualquer usuário autenticado pode ler notificações
      allow read: if isAuthenticated();
      
      // Apenas o criador ou admin pode deletar (limpeza automática)
      allow delete: if isAuthenticated() 
        && (resource.data.userId == request.auth.uid || isAdmin());
    }

    // Notificações de delta para aprovações (somente backend grava)
    match /realtimeAprovacaoNotifications/{notificationId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if false;
    }

    // Agregados diários de aprovações (somente leitura no cliente)
    match /aprovacoesAggDaily/{dateKey} {
      allow read: if isAuthenticated();
      allow create, update, delete: if false;
    }

    // Agregado global de aprovações (somente leitura no cliente)
    match /aprovacoesAggSummary/{docId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if false;
    }

    // Links de conversão aprovação -> processo materializados no backend
    match /aprovacaoConversaoLinks/{processoId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if false;
    }

    // ===================== LOGS DE ATIVIDADE =====================
    
    // Logs de atividade do sistema
    match /activity_logs/{activityId} {
      allow read: if isAdmin()
        || (isAuthenticated() && resource.data.userUid == request.auth.uid);
      allow create: if isAuthenticated()
        && request.resource.data.keys().hasOnly([
          'actionType',
          'description',
          'relatedEntityId',
          'extraData',
          'timestamp',
          'userName',
          'userEmail',
          'userUid',
          'actorName',
          'actorEmail',
          'actorUid',
          'module',
          'page',
          'entityType',
          'entityLabel',
          'oldValue',
          'newValue',
          'filename',
          'rowCount',
          'storagePath',
          'storageDownloadUrl',
          'mimeType',
          'fileSize'
        ])
        && request.resource.data.actionType is string
        && request.resource.data.description is string
        && request.resource.data.timestamp is timestamp
        && request.resource.data.timestamp == request.time
        && request.resource.data.userName is string
        && request.resource.data.userUid == request.auth.uid
        && request.resource.data.userEmail == request.auth.token.email
        && (!('actorName' in request.resource.data) || request.resource.data.actorName == null || request.resource.data.actorName is string)
        && (!('actorEmail' in request.resource.data) || request.resource.data.actorEmail == null || request.resource.data.actorEmail is string)
        && (!('actorUid' in request.resource.data) || request.resource.data.actorUid == null || request.resource.data.actorUid is string)
        && (!('module' in request.resource.data) || request.resource.data.module == null || request.resource.data.module is string)
        && (!('page' in request.resource.data) || request.resource.data.page == null || request.resource.data.page is string)
        && (!('entityType' in request.resource.data) || request.resource.data.entityType == null || request.resource.data.entityType is string)
        && (!('entityLabel' in request.resource.data) || request.resource.data.entityLabel == null || request.resource.data.entityLabel is string)
        && (!('oldValue' in request.resource.data) || request.resource.data.oldValue == null || request.resource.data.oldValue is string)
        && (!('newValue' in request.resource.data) || request.resource.data.newValue == null || request.resource.data.newValue is string)
        && (!('filename' in request.resource.data) || request.resource.data.filename == null || request.resource.data.filename is string)
        && (!('rowCount' in request.resource.data) || request.resource.data.rowCount == null || request.resource.data.rowCount is number)
        && (!('storagePath' in request.resource.data) || request.resource.data.storagePath == null || request.resource.data.storagePath is string)
        && (!('storageDownloadUrl' in request.resource.data) || request.resource.data.storageDownloadUrl == null || request.resource.data.storageDownloadUrl is string)
        && (!('mimeType' in request.resource.data) || request.resource.data.mimeType == null || request.resource.data.mimeType is string)
        && (!('fileSize' in request.resource.data) || request.resource.data.fileSize == null || request.resource.data.fileSize is number)
        && (!('relatedEntityId' in request.resource.data) || request.resource.data.relatedEntityId == null || request.resource.data.relatedEntityId is string)
        && (!('extraData' in request.resource.data) || request.resource.data.extraData is map);
      allow update, delete: if isAdmin();
    }

    // ===================== REGRAS PADRÃO =====================

    // Qualquer outra coleção - requer admin
    match /{document=**} {
      allow read, write: if isAdmin();
    }
  }
}
